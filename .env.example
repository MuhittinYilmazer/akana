# Akana — .env template. Copy: `cp .env.example .env` and fill in the values.
# NEVER commit real keys (.gitignore already excludes .env).
# NOTE: Secrets can also be entered from the settings panel (cursor_api_key,
# claude_oauth_token, telegram_bot_token → secret_store). Panel takes priority over env.

# ── Server ───────────────────────────────────────────────────────────────────
# Bind address and port (defaults shown; change the port if 8766 is already in use)
AKANA_HOST=127.0.0.1
AKANA_PORT=8766

# Optional bearer token for /api/v1/* (empty = auth off).
# ⚠️ SECURITY: If left empty the API is reachable without auth (vault write, credentials,
# files/read, chat→LLM). There are two layers of protection:
#   • Loopback (127.0.0.1) bind + a DIRECT local request → open mode works (easy dev).
#   • A request through a reverse proxy (Tailscale Serve / nginx / PWA) + empty token
#     → REJECTED with 401. A token is REQUIRED for phone/remote access; binding to
#     loopback does NOT protect you behind a proxy (the bind address can't see the proxy).
#   • Non-loopback bind (0.0.0.0 etc.) + empty token → the server REFUSES to start.
# Generate a strong random value: `python -c "import secrets;print(secrets.token_urlsafe(32))"`
AKANA_TOKEN=

# "1" = deliberately accept unauthenticated open mode: the rejections above drop to a
# warning (proxied requests also pass without a token). Use only on a network you trust.
# AKANA_ALLOW_UNAUTHENTICATED=0

# Persistent data root (SQLite, audit, skills, approvals, voices)
AKANA_DATA_DIR=~/.akana

# Cursor agent working directory (default: repo root)
# AKANA_WORKSPACE=~/Projects/my-app

# UI / voice / Akana's default persona language: en (default) | tr.
# Can also be changed from the settings panel (panel takes priority over env).
AKANA_LANGUAGE=en

# Log level: DEBUG | INFO | WARNING | ERROR
# LOG_LEVEL=INFO

# ── Providers (LLM) ──────────────────────────────────────────────────────────
# Provider selection: "cursor" (Cursor SDK) | "claude" (local claude CLI, subscription) |
# "ollama" (local model) | "gemini" (direct Google API) | "openai" (direct OpenAI API)
# LLM_PROVIDER=cursor

# Cursor SDK key (for LLM_PROVIDER=cursor): https://cursor.com/dashboard/integrations
# Left commented out on purpose: an active placeholder value fooled the CLI's
# "configured?" check, so fresh installs got a silent 401 on the first chat.
# Uncomment this line and paste your key here (or enter it from the settings panel).
# CURSOR_API_KEY=

# Default Cursor model tag (overridden from the UI via ~/.akana/llm_settings.json)
CURSOR_MODEL=composer-2

# Cursor bridge idle timeout (seconds) — 1800 recommended for long tasks
# CURSOR_BRIDGE_TIMEOUT=1800

# CLI binary, model, and timeout for the claude provider (run `claude login` first)
# CLAUDE_BIN=claude
# CLAUDE_MODEL=claude-sonnet-4-6
# CLAUDE_BRIDGE_TIMEOUT=1800

# Ollama local-model provider (for LLM_PROVIDER=ollama; run `ollama serve` first).
# A simple local LLM — no MCP tools / agent-reuse / effort (cursor/claude have those).
# AKANA_OLLAMA_URL=http://localhost:11434
# AKANA_OLLAMA_MODEL=llama3.1
# Max seconds to wait for the next token while streaming (cold model load / slow CPU).
# 0 = no limit (never time out — default). The connect timeout stays short regardless.
# AKANA_OLLAMA_TIMEOUT=0

# OpenAI direct-API provider (for LLM_PROVIDER=openai) — your own key (NOT the Cursor
# key; the panel's openai_api_key secret takes priority over env). The model is chosen
# from the UI via ~/.akana/llm_settings.json (openai_model); OPENAI_MODEL is only an env
# fallback. OPENAI_BASE_URL is for a compatible/custom endpoint (Azure/proxy).
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-5.4

# Gemini direct-API provider (for LLM_PROVIDER=gemini) and Gemini Live voice — your own
# key (the panel's gemini_api_key secret takes priority; this is the Google SDK's own
# canonical env fallback name).
# GEMINI_API_KEY=

# Gemini Live (full-duplex native-audio voice) — when provider=gemini the voice-chat
# button switches to real-time mode. OFF by default (audio streams to Google, opt-in);
# uses your own gemini_api_key. The model/voice are Live preview native-audio names.
# AKANA_GEMINI_LIVE_ENABLED=0
# AKANA_GEMINI_LIVE_MODEL=models/gemini-2.5-flash-native-audio-latest
# AKANA_GEMINI_LIVE_VOICE=Charon
# OpenAI Realtime (the twin of Gemini Live): when provider==openai the voice button
# switches to real-time mode. OFF by default (audio streams to OpenAI, opt-in); uses
# your own openai_api_key. Audio is PCM16@24k.
# AKANA_OPENAI_REALTIME_ENABLED=0
# AKANA_OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview
# AKANA_OPENAI_REALTIME_VOICE=marin

# LLM hang protection: idle ceiling if the stream stops producing chunks (s), 0=off
# AKANA_LLM_IDLE_TIMEOUT=120
# LLM hang protection: total-time ceiling for a non-streaming (one-shot) call (s), 0=off
# AKANA_LLM_TOTAL_TIMEOUT=300

# Full tool authority on the claude provider (bypassPermissions) — use with care
# AKANA_CLAUDE_FULL_TOOLS=0

# Autonomous continuation: after a coding turn the agent keeps working (via --resume)
# until it signals completion, instead of stopping after one headless run. 0=off (default)
# AKANA_AGENT_AUTOCONTINUE=0
# Safety ceiling: max number of auto-continue iterations for a single turn
# AKANA_AGENT_MAX_CONTINUE_ITERS=25
# Safety ceiling: wall-clock deadline (s) for a single auto-continuing turn, 0=off
# AKANA_AGENT_CONTINUE_DEADLINE=0

# ── Voice: TTS (Piper / Edge) ────────────────────────────────────────────────
# Piper voice models directory (default: $AKANA_DATA_DIR/voices)
# AKANA_VOICES_DIR=

# Specific .onnx voice files (absolute path or relative to the voices directory)
# PIPER_VOICE_TR=tr_TR-dfki-medium.onnx
# PIPER_VOICE_EN=en_US-amy-medium.onnx

# Force the TTS engine: empty = user preference; "auto" | "edge" | "piper"
# AKANA_TTS_ENGINE=

# Edge TTS hang ceiling (seconds). This is NOT a piper TRIGGER: if edge is slow
# (jitter) we do not drop to robotic piper, we wait for the natural voice up to this
# limit; if the ceiling is exceeded the sentence is skipped. If the network is dead a
# connection error already drops to piper instantly. Default: 10
# AKANA_TTS_EDGE_TIMEOUT_S=10

# Maximum characters per TTS request
# VOICE_TTS_MAX_CHARS=5000

# ── Voice: STT (faster-whisper) ──────────────────────────────────────────────
# If you see a libcublas/CUDA error (503 /voice/transcribe) use cpu
# WHISPER_DEVICE=auto
# WHISPER_MODEL=small
# WHISPER_COMPUTE_TYPE=int8

# Maximum recording length (seconds). The primary language now follows the `language`
# setting (Settings → General → Language); the separate VOICE_PRIMARY_LANG override was removed.
# VOICE_MAX_RECORD_SECONDS=60

# ── Voice: wake word ─────────────────────────────────────────────────────────
# "Hey Akana" wake detection has two sources, picked in the voice settings UI:
#  • model (DEFAULT): a custom-trained openWakeWord model shipped in the repo
#    (akana_server/voice/wake_models/hey_akana.onnx). Needs the voice extra
#    (openwakeword). Local, accurate, threshold-tunable.
#  • browser: SpeechRecognition phrase-match, no dependency, no threshold.
# WAKE_MODEL is unset here so the bundled model is used automatically; set it to
# another model path to override, or to empty to force the browser source.
# WAKE_MODEL=
# WAKE_THRESHOLD=0.5
# WAKE_INFERENCE_FRAMEWORK=onnx
# Auto-start the wake listener on server boot (1/0; empty = preference file)
# AKANA_WAKE_AUTOSTART=

# ── Memory and background jobs ───────────────────────────────────────────────
# LLM-based memory capture (1 = on)
# AKANA_MEMORY_LLM_CAPTURE=1

# Give the agent the akana_memory MCP tools (0 = off)
# AKANA_MEMORY_TOOLS=1

# Boot-time MCP self-check: spawn the built-in MCP servers once and log whether they
# connect, so server.log answers "is memory connected?". 1 = on (default), 0 = off.
# AKANA_MCP_SELFCHECK=1

# Direct-write permission in the memory MCP and the vector-search switch (empty = preference file)
# AKANA_MEMORY_ALLOW_DIRECT=
# AKANA_MEMORY_VECTOR=
# Vector embedding source: local (local fastembed, default) | ollama | off
# AKANA_MEMORY_EMBED_BACKEND=local
# Where the local fastembed model (~220MB) is cached. Default: <XDG_CACHE_HOME or
# ~/.cache>/fastembed (reboot-persistent). Set this to relocate the cache; do NOT
# point it at /tmp on Linux — /tmp is cleared on reboot, forcing a re-download each boot.
# FASTEMBED_CACHE_PATH=

# Auto-generate a short conversation title from the first turn via the LLM (1 = on, the
# default; 0 = off → conversations keep their placeholder name).
# AKANA_LLM_CHAT_TITLES=1

# SessionCloser cron: idle chat summaries to the inbox (interval seconds, 0 = off)
# AKANA_SESSION_CLOSER_ENABLED=1
# AKANA_SESSION_CLOSER_INTERVAL=300
# AKANA_SESSION_CLOSER_IDLE_MINUTES=30
# Long-chat summary threshold: summarize once this many new turns accumulate, without waiting for idle (0=off)
# AKANA_SESSION_CLOSER_TURN_THRESHOLD=20
# Content-aware variant: summarize once this many new user/assistant chars accumulate since the last summary (0=off)
# AKANA_SESSION_CLOSER_CHAR_THRESHOLD=4000
# Summarization chunk size: transcript summarized in chunks of this many chars (min 200)
# AKANA_SESSION_CLOSER_MAX_CHARS=6000
# Prior-context recall: fold the rolling session summary back into each turn as a «Prior context» block (1=on)
# AKANA_SESSION_SUMMARY_INJECT=1
# Prior-context recall budget: hard cap (chars) on the injected block; 0 = no cap
# AKANA_SESSION_SUMMARY_INJECT_MAX_CHARS=1500
# Summary consolidation cron: cluster related session summaries → one staged candidate (1=on; interval seconds, 0=off)
# AKANA_SUMMARY_CONSOLIDATION_ENABLED=1
# AKANA_SUMMARY_CONSOLIDATION_INTERVAL=3600
# Consolidation overlap threshold: shared topical words before two summaries cluster (min 1)
# AKANA_SUMMARY_CONSOLIDATION_MIN_OVERLAP=2

# ── Tasks + Skills ───────────────────────────────────────────────────────────
# Per-turn skill injection: 0/false/off = off (default on)
# AKANA_SKILL_INJECT=1

# Installed-skill catalog (a title+trigger inventory in the system prompt): 0/false/off = off (default on)
# AKANA_SKILL_CATALOG=1

# Catalog size ceilings — how many capabilities / how many chars the inventory may use
# (overflow is summarized with a visible "(+N more)" note, never dropped silently)
# AKANA_SKILL_CATALOG_MAX_ENTRIES=256
# AKANA_SKILL_CATALOG_MAX_CHARS=20000

# Min RRF score for non-trigger matches and max skills injected per turn
# AKANA_SKILL_INJECT_THRESHOLD=0.03
# AKANA_SKILL_INJECT_MAX=1

# Time budget for the skill-suggestion search (seconds)
# AKANA_SKILL_SUGGEST_TIMEOUT_S=1.5

# Extra Cursor skill directories (comma-separated)
# AKANA_SKILL_PATHS=

# FileEngine F0: allowed roots for Akana's own file tools (":"-separated; empty = disabled)
# AKANA_FILE_ROOTS=~/Documents/notes:~/Projects/app-a

# ── Context (ContextEngine) ──────────────────────────────────────────────────
# Total context character limit per turn (system+history+user text; on overflow
# history is trimmed first, then the skill block; 0 = unlimited)
# AKANA_CONTEXT_MAX_CHARS=120000
# Fast path: for short messages below this threshold that do not look multi-step,
# planner.route/decompose is skipped and skill suggestion runs with a 0.5s budget
# (0 = fast path off; ChatRequest.thinking_mode=fast ignores the threshold)
# AKANA_FAST_PATH_MAX_CHARS=80

# ── Security ─────────────────────────────────────────────────────────────────
# Secure-vault MCP server toggle: vault_list/vault_get/vault_get_credential read tools
# added to the claude turn (default on; "0" = off).
# AKANA_VAULT_TOOLS=1

# SecureVault encryption key source (vault_crypto.py). All have a SAFE default: the key
# is auto-generated at $XDG_CONFIG_HOME/akana/vault.key (0600) on first use — none of
# these are required. Optional overrides, in priority order:
# Raw urlsafe-base64 Fernet master key (CI/advanced override; if set, keyfile/keyring are skipped)
# AKANA_VAULT_KEY=
# Path to the master key file (default $XDG_CONFIG_HOME/akana/vault.key); for a portable vault
# AKANA_VAULT_KEYFILE=
# "1" = store the master key in the OS keyring instead of a keyfile (default off)
# AKANA_VAULT_KEYRING=0

# ── Connectors (Telegram) ────────────────────────────────────────────────────
# Telegram bridge (OFF by default; without enable + token + allowlist polling won't start)
# AKANA_TELEGRAM_ENABLED=0

# Bot token (from BotFather; the panel's telegram_bot_token takes priority over env)
# AKANA_TELEGRAM_BOT_TOKEN=

# Allowed chat ids (comma-separated; empty = everyone is rejected)
# AKANA_TELEGRAM_ALLOWED_CHAT_IDS=123456789

# Channel history character budget (≈ tokens*4)
# AKANA_CONNECTOR_HISTORY_BUDGET=12000

# Per-channel persona: AKANA_PERSONA_<CHANNEL>=persona_id (e.g. the telegram channel)
# AKANA_PERSONA_TELEGRAM=

# ── Network resilience (NetworkEngine F0) ────────────────────────────────────
# A retry + circuit-breaker + timeout layer wrapping LLM provider/CLI calls.
# All also configurable from the panel (Network Resilience category) without a restart.
# Max attempts on a transient error (timeout/5xx/429) (1 = no retry); auth is never retried
# AKANA_NETWORK_MAX_RETRIES=3
# Exponential backoff: initial delay, ceiling, and jitter ratio (seconds / 0-1)
# AKANA_NETWORK_BASE_DELAY=0.5
# AKANA_NETWORK_MAX_DELAY=8
# AKANA_NETWORK_JITTER=0.25
# Total time budget across all attempts (seconds; 0 = unlimited)
# AKANA_NETWORK_TOTAL_TIMEOUT=60
# Circuit breaker: consecutive-error threshold per provider (0 = off) and cooldown (s)
# AKANA_NETWORK_BREAKER_THRESHOLD=5
# AKANA_NETWORK_BREAKER_COOLDOWN=30

# ── Advanced / bridge ────────────────────────────────────────────────────────
# Bridge daemon mode and agent-session reuse (0 = off)
# AKANA_BRIDGE_DAEMON=1
# AKANA_REUSE_AGENT=1
# Graceful shutdown: send a shutdown op to the daemon (instead of force-killing with
# killpg); the daemon exits via process.exit(0) → the orphan reaper won't find a live
# process on the next boot, and Cursor cloud sessions keep resuming with the agent id in
# the DB (1 = on; off by default)
# AKANA_BRIDGE_SOFT_SHUTDOWN=1

# ── Multimodal (multi-type file upload) ──────────────────────────────────────
# Upload feature switch (0 = POST /uploads off; records are preserved)
# Accepted types: image (png/jpg/webp/gif) + text/code + pdf/docx/xlsx/pptx/zip
# AKANA_UPLOADS_ENABLED=1

# Per-file upper size limit (MB)
# AKANA_UPLOAD_MAX_MB=10
